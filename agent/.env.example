# MeetPrep AI Agent — Environment Variables
# ─────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your keys below
# 3. The agent auto-reads this file on startup (no export needed!)

# ── GROQ (Required) ──────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── HINDSIGHT CLOUD (Optional) ───────────────────────────────────
# Sign up at: https://ui.hindsight.vectorize.io
# Use promo code MEMHACK6 for $50 free credits
# If not set / unreachable, agent runs in LOCAL MODE (local_memory.json)
HINDSIGHT_URL=https://your-instance.hindsight.vectorize.io
HINDSIGHT_API_KEY=your_hindsight_api_key_here
